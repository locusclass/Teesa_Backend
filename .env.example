# ─────────────────────────────────────────────────────────────────
# Teesa Backend — Environment Variables
# Copy to .env for local development. On Railway, set these in
# the service's "Variables" tab (never commit a real .env to git).
# ─────────────────────────────────────────────────────────────────

NODE_ENV=development
# PORT is injected automatically by Railway — do not set it there.
PORT=3000

# ── Database ──────────────────────────────────────────────────────
# Railway PostgreSQL plugin sets DATABASE_URL automatically.
# For local dev, create a DB and fill this in.
DATABASE_URL=postgresql://teesa:teesa_password@localhost:5432/teesa_db

# ── JWT ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_minimum_32_characters_long_random_string
JWT_REFRESH_SECRET=CHANGE_ME_different_minimum_32_characters_long

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or '*' to allow all.
# On Railway, add your Flutter web app's Railway URL:
#   e.g. https://teesa-admin.up.railway.app,https://yourdomain.com
# Use '*.railway.app' to allow all Railway subdomains.
CORS_ORIGINS=*

# ── Google Maps (optional) ────────────────────────────────────────
# Without this, Haversine formula is used as fallback.
GOOGLE_MAPS_API_KEY=

# ── Google Cloud Storage (optional) ──────────────────────────────
# Without these, files are stored locally in ./uploads/
GCS_BUCKET=
GCP_PROJECT_ID=
GCP_KEY_FILE=

# ── SMS / Africa's Talking (optional) ────────────────────────────
# Without AT_API_KEY, OTPs are logged to console (mock mode).
SMS_PROVIDER=mock
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=TEESA

# ── Payments (optional) ───────────────────────────────────────────
MOBILE_MONEY_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=

# ── Redis (optional) ──────────────────────────────────────────────
# Add Railway Redis plugin to get this automatically.
# Required only if you scale the API to multiple instances.
REDIS_URL=

# ── Admin Bootstrap ───────────────────────────────────────────────
ADMIN_BOOTSTRAP_EMAIL=admin@teesa.ug
ADMIN_BOOTSTRAP_PHONE=+256700000000

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ── OTP ───────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
