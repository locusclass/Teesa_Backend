NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://teesa:teesa_password@localhost:5432/teesa_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:4200

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Cloud Storage
GCS_BUCKET=teesa-uploads
GCP_PROJECT_ID=your-gcp-project-id
GCP_KEY_FILE=./gcp-key.json

# SMS / Africa's Talking
SMS_PROVIDER=africas_talking
AT_USERNAME=sandbox
AT_API_KEY=your-africas-talking-api-key
AT_SENDER_ID=TEESA

# Payment
MOBILE_MONEY_PROVIDER=mtn_momo
PAYMENT_WEBHOOK_SECRET=your-webhook-secret

# Admin Bootstrap
ADMIN_BOOTSTRAP_EMAIL=admin@teesa.ug
ADMIN_BOOTSTRAP_PHONE=+256700000000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
